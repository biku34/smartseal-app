# Copy this file to .env.local for local dev, and set the same keys in Vercel
# (Project → Settings → Environment Variables). Never commit real secrets.

# MongoDB Atlas connection string (Driver → Node.js), with /smartseal as the db name
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartseal?retryWrites=true&w=majority&appName=Cluster0

# Long random string used to sign auth JWTs:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Cloudinary (product photo storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=smartseal/products
